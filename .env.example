APP_NAME="Yalla Spare"
# Production deploys must use APP_ENV=production and APP_DEBUG=false.
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Replace with the real HTTPS public origin before deployment.
APP_URL=https://www.example.com
CORS_ALLOWED_ORIGINS=https://www.example.com
TRUSTED_HOSTS=www.example.com,example.com
LOW_STOCK_THRESHOLD=5

ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=database
CACHE_PREFIX=yallaspare
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
SESSION_DRIVER=file
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=.example.com
SESSION_LIFETIME=120

# When the app sits behind a reverse proxy that rewrites client IPs.
# Accepted values:
#   cloudflare         -> trust the published Cloudflare edge ranges
#   "1.2.3.4,5.6.7.8"  -> trust the listed proxies
#   "*"                -> trust any proxy (only safe behind a known LB)
#   (unset)            -> trust nothing (default)
# Required so $request->ip() / IntrusionPrevention / rate limiters see the
# real client address and not Cloudflare's edge node.
TRUSTED_PROXIES=
ADMIN_TWO_FACTOR_ENABLED=true
ADMIN_TWO_FACTOR_CODE_TTL=10
USER_TWO_FACTOR_CODE_TTL=10
INTRUSION_PREVENTION_ENABLED=false
INTRUSION_PREVENTION_WINDOW_MINUTES=10
INTRUSION_PREVENTION_BLOCK_MINUTES=30
INTRUSION_PREVENTION_MAX_SCORE=8

DASHBOARD_CACHE_TTL=60
NOTIFICATION_CACHE_TTL=30
PRODUCTS_META_CACHE_TTL=300

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=support.yallaspare@gmail.com
MAIL_PASSWORD=PASTE_REAL_APP_PASSWORD_HERE
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=support.yallaspare@gmail.com
MAIL_FROM_NAME="Yalla Spare"
MAIL_EHLO_DOMAIN=yallaspare.com
MAIL_TIMEOUT=15
MAIL_SUPPORT_ADDRESS=support.yallaspare@gmail.com
MAIL_FAILOVER_MAILERS=smtp,log

PAYMENT_CURRENCY=IQD
FIB_PAYMENTS_ENABLED=false
FIB_BASE_URL=https://fib.stage.fib.iq
FIB_CLIENT_ID=
FIB_CLIENT_SECRET=
FIB_WEBHOOK_TOKEN=

ZAINCASH_PAYMENTS_ENABLED=false
ZAINCASH_BASE_URL=https://test.zaincash.iq
ZAINCASH_MERCHANT_ID=
ZAINCASH_MSISDN=
ZAINCASH_SECRET=
ZAINCASH_SERVICE_TYPE="Yalla Spare order"
ZAINCASH_WEBHOOK_TOKEN=

FASTPAY_PAYMENTS_ENABLED=false

# Gmail SMTP preset:
# MAIL_MAILER=gmail
# MAIL_GMAIL_USERNAME=support.yallaspare@gmail.com
# MAIL_GMAIL_PASSWORD=PASTE_GMAIL_APP_PASSWORD_HERE

# Hostinger SMTP preset:
# MAIL_MAILER=hostinger
# MAIL_HOSTINGER_HOST=smtp.hostinger.com
# MAIL_HOSTINGER_PORT=465
# MAIL_HOSTINGER_ENCRYPTION=ssl
# MAIL_HOSTINGER_USERNAME=no-reply@yallaspare.com
# MAIL_HOSTINGER_PASSWORD=PASTE_HOSTINGER_SMTP_PASSWORD_HERE

# Mailtrap fallback/testing preset:
# MAIL_MAILER=mailtrap
# MAILTRAP_HOST=sandbox.smtp.mailtrap.io
# MAILTRAP_PORT=2525
# MAILTRAP_ENCRYPTION=tls
# MAILTRAP_USERNAME=PASTE_MAILTRAP_USERNAME_HERE
# MAILTRAP_PASSWORD=PASTE_MAILTRAP_PASSWORD_HERE

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
