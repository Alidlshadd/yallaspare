APP_NAME="Yalla Spare"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1:8000
LOW_STOCK_THRESHOLD=5

ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=database
CACHE_PREFIX=yallaspare
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
SESSION_DRIVER=file
SESSION_SECURE_COOKIE=false
SESSION_LIFETIME=120
ADMIN_TWO_FACTOR_ENABLED=false
ADMIN_TWO_FACTOR_CODE_TTL=10
INTRUSION_PREVENTION_ENABLED=false
INTRUSION_PREVENTION_WINDOW_MINUTES=10
INTRUSION_PREVENTION_BLOCK_MINUTES=30
INTRUSION_PREVENTION_MAX_SCORE=8

DASHBOARD_CACHE_TTL=60
NOTIFICATION_CACHE_TTL=30
PRODUCTS_META_CACHE_TTL=300

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=support.yallaspare@gmail.com
MAIL_PASSWORD=PASTE_REAL_APP_PASSWORD_HERE
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=support.yallaspare@gmail.com
MAIL_FROM_NAME="Yalla Spare"
MAIL_EHLO_DOMAIN=yallaspare.com
MAIL_TIMEOUT=15
MAIL_SUPPORT_ADDRESS=support.yallaspare@gmail.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
